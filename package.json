{
  "name": "@jsse/fastify-shitty",
  "version": "1.0.0",
  "private": false,
  "description": "Plugin to make fastify shittier",
  "keywords": [
    "fastify",
    "plugin",
    "fastify-plugin"
  ],
  "license": "MIT",
  "author": "jessekrubin",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/fastify-shitty.cjs",
  "module": "dist/fastify-shitty.mjs",
  "types": "dist/fastify-shitty.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/fastify-shitty.d.mts",
        "default": "./dist/fastify-shitty.mjs"
      },
      "require": {
        "types": "./dist/fastify-shitty.d.cts",
        "default": "./dist/fastify-shitty.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "fmt": "prettier --write .",
    "fmtc": "prettier --check .",
    "test": "vitest run && pnpm run build && pnpm run lint",
    "lint": "eslint .",
    "build": "tsc --noEmit && tsdown --dts --clean && vitest --run",
    "dev": "vitest",
    "prepublish": "pnpm build"
  },
  "dependencies": {
    "fastify-plugin": "^6.0.0"
  },
  "devDependencies": {
    "@jsse/eslint-config": "^0.9.6",
    "@jsse/tsconfig": "^0.5.1",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "eslint": "^10.7.0",
    "fastify": "^5.9.0",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "tsdown": "^0.22.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
